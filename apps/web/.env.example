# Optional: only enable if you actually use cookie auth in dev (verifies /api/auth/me once).
# For most local dev and Playwright, keep false or unset.
VITE_VERIFY_COOKIE_AUTH_IN_DEV=false

# Land parcel documents (upload). Keep false until backend storage (e.g. S3) is configured.
# VITE_LAND_DOCUMENTS_ENABLED=false

# --- API in local dev (fixes 404 on http://localhost:3000/api/...) ---
# Leave VITE_API_URL unset so the browser calls relative /api/... and Vite proxies to Laravel.
#
# Proxy target for `npm run dev` and `npm run preview` (see vite.config.ts). Default: http://localhost:8000
# If you use Laragon/Apache instead of `php artisan serve`, point this at your app URL, e.g.:
# VITE_DEV_API_PROXY_TARGET=http://farm-erp-v2.test
#
# Only set this if you must bypass the proxy (e.g. mobile testing). Requires CORS on the API.
# VITE_API_URL=http://localhost:8000
